# ─── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=cursos-medicos
PINECONE_ENVIRONMENT=us-east-1

# ─── Redis ───────────────────────────────────────────────────────────────────
# REDIS_PASSWORD is consumed by docker-compose to start redis with --requirepass.
# REDIS_URL must include the password so the API can auth (format: redis://:PASSWORD@host:port/db).
REDIS_PASSWORD=change-me-to-a-strong-secret
REDIS_URL=redis://:change-me-to-a-strong-secret@redis:6379/0

# ─── Zoho CRM ────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_REDIRECT_URI=https://your-domain.com/auth/zoho/callback
ZOHO_BASE_URL=https://www.zohoapis.com/crm/v6
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# ─── Botmaker ────────────────────────────────────────────────────────────────
# OAuth2 (recomendado): clientId + secretId + refreshToken
BOTMAKER_CLIENT_ID=
BOTMAKER_SECRET_ID=
BOTMAKER_REFRESH_TOKEN=
# Alternativa: access-token estático (solo para dev/testing)
BOTMAKER_API_KEY=
BOTMAKER_BASE_URL=https://go.botmaker.com/api/v1.0
BOTMAKER_WEBHOOK_SECRET=

# ─── MercadoPago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=

# ─── Rebill ──────────────────────────────────────────────────────────────────
REBILL_API_KEY=
REBILL_BASE_URL=https://api.rebill.to/v2
REBILL_ORGANIZATION_ID=

# ─── LMS: Moodle ─────────────────────────────────────────────────────────────
MOODLE_BASE_URL=https://campus.yoursite.com
MOODLE_TOKEN=

# ─── LMS: Blackboard ─────────────────────────────────────────────────────────
BLACKBOARD_BASE_URL=https://yourinstance.blackboard.com
BLACKBOARD_APP_KEY=
BLACKBOARD_APP_SECRET=

# ─── LMS: Tropos ─────────────────────────────────────────────────────────────
TROPOS_BASE_URL=https://api.tropos.com
TROPOS_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-secret
APP_BASE_URL=https://your-domain.com
ALLOWED_ORIGINS=https://yourwordpress.com,http://localhost:3000

# ─── Sentry (error tracking) ─────────────────────────────────────────────────
# Dejar vacío para desactivar. DSN desde sentry.io → project → Client Keys.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Cloudflare R2 (object storage) ──────────────────────────────────────────
# Dejar vacío para usar filesystem local. Credenciales desde Cloudflare R2 → Manage API Tokens.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Notificaciones humanas (handoff)
SLACK_WEBHOOK_URL=
NOTIFICATION_EMAIL=operaciones@tuempresa.com
